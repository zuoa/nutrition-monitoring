FLASK_ENV=development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nutrition_db
POSTGRES_USER=nutrition
POSTGRES_PASSWORD=nutrition_dev
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SECRET_KEY=dev-secret-key-change-in-production
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
QWEN_API_KEY=

# OpenAI-compatible API (for dish nutrition analysis, default to DeepSeek)
# Supports: DeepSeek, OpenAI, or any OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Video source: "nvr" (default) or "hikvision_camera"
VIDEO_SOURCE_MODE=nvr
# Required when VIDEO_SOURCE_MODE=hikvision_camera
# JSON: {"1": {"host": "192.168.1.101", "port": 80, "username": "admin", "password": "xxx"}}
HIKVISION_CAMERAS={}
