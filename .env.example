# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here

# ─── Application ─────────────────────────────────────────────────────────────
SECRET_KEY=your_very_long_random_secret_key_here
FLASK_ENV=production

# ─── DingTalk ─────────────────────────────────────────────────────────────────
DINGTALK_APP_KEY=dingxxxxxxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_AGENT_ID=1234567890
DINGTALK_CORP_ID=ding_corp_id_here

# ─── Qwen3-VL AI ──────────────────────────────────────────────────────────────
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-vl-max
QWEN_MAX_QPS=10

# ─── OpenAI-compatible API (for dish nutrition analysis, default to DeepSeek) ─
# Supports: DeepSeek, OpenAI, or any OpenAI-compatible API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ─── NVR ──────────────────────────────────────────────────────────────────────
NVR_HOST=192.168.1.100
NVR_PORT=8080
NVR_USERNAME=admin
NVR_PASSWORD=your_nvr_password
NVR_CHANNEL_IDS=1,2
NVR_MEAL_WINDOWS=[{"start":"11:30","end":"13:00"},{"start":"17:30","end":"19:00"}]

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://nutrition.school.edu.cn

# ─── Flower (Celery monitoring) ───────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=your_flower_password
