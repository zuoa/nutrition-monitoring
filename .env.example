# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
# Optional explicit DB parts; normally only password needs changing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nutrition_db
POSTGRES_USER=nutrition
REDIS_PASSWORD=your_secure_redis_password_here

# ─── Application ─────────────────────────────────────────────────────────────
SECRET_KEY=your_very_long_random_secret_key_here
FLASK_ENV=production

# ─── DingTalk ─────────────────────────────────────────────────────────────────
DINGTALK_APP_KEY=dingxxxxxxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_AGENT_ID=1234567890
DINGTALK_CORP_ID=ding_corp_id_here

# ─── Qwen3-VL AI ──────────────────────────────────────────────────────────────
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-vl-max
QWEN_MAX_QPS=10

# ─── OpenAI-compatible API (for dish nutrition analysis, default to DeepSeek) ─
# Supports: DeepSeek, OpenAI, or any OpenAI-compatible API
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ─── NVR ──────────────────────────────────────────────────────────────────────
NVR_HOST=192.168.1.100
NVR_PORT=8080
NVR_USERNAME=admin
NVR_PASSWORD=your_nvr_password
NVR_CHANNEL_IDS=1,2
NVR_MEAL_WINDOWS=[{"start":"11:30","end":"13:00"},{"start":"17:30","end":"19:00"}]

# ─── Video Analysis ───────────────────────────────────────────────────────────
# DIFF_THRESHOLD: 帧差分阈值，超过此值认为有运动 (默认30)
# PLATE_PIXEL_THRESHOLD: 与背景相比的像素变化阈值，用于判断ROI中是否有餐盘 (默认5000)
# 如果ROI较大或餐盘较大，可适当调高；如果误检/漏检严重，可适当调整
# DIFF_THRESHOLD=30
# PLATE_PIXEL_THRESHOLD=5000

# ENABLE_PLATE_FILTER: 是否启用后置餐盘检测过滤 (默认true)
# 视频分析后会再次检测图片中是否有餐盘，过滤掉无餐盘的图片
# ENABLE_PLATE_FILTER=true

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://nutrition.school.edu.cn

# ─── Internal Inference Services ──────────────────────────────────────────────
INFERENCE_API_TOKEN=change_me_internal_token
INFERENCE_API_TIMEOUT=180
INFERENCE_CONTROL_TIMEOUT=3
DETECTOR_API_BASE_URL=http://detector-api:5000
RETRIEVAL_API_BASE_URL=http://retrieval-api:5000
HF_ENDPOINT=https://hf-mirror.com
YOLO_MAX_REGIONS=6
YOLO_MODEL_PATH=/models/yolo/best.pt
INFERENCE_LOCAL_MODEL_STORAGE_PATH=/data/models
INFERENCE_LOCAL_EMBEDDING_INDEX_DIR=/data/index
INFERENCE_LOCAL_QWEN3_VL_EMBEDDING_MODEL_PATH=/data/models/qwen3-vl-embedding-2b
INFERENCE_LOCAL_QWEN3_VL_RERANKER_MODEL_PATH=/data/models/qwen3-vl-reranker-2b

# ─── Flower (Celery monitoring) ───────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=your_flower_password
